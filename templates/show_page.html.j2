{% extends "base.html.j2" %}

{% block head_extra %}
<!-- Schema.org PodcastSeries -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "PodcastSeries",
  "name": {{ show_name | tojson }},
  "description": {{ meta_description | tojson }},
  "url": {{ canonical_url | tojson }},
  "webFeed": "{{ path_prefix }}{{ rss_file }}"{% if podcast_image_url %},
  "image": "{{ podcast_image_url }}"{% endif %}{% if apple_podcasts_url %},
  "sameAs": [{{ apple_podcasts_url | tojson }}]{% endif %}
}
</script>
<style>
    @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
    }
    .skeleton-card {
        background: rgba(255,255,255,0.05);
        border-radius: 12px;
        padding: 1.5rem;
    }
    .skeleton-line {
        height: 14px;
        background: linear-gradient(90deg, rgba(255,255,255,0.06) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.06) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        border-radius: 4px;
        margin-bottom: 0.75rem;
    }
    .skeleton-title { width: 70%; height: 18px; }
    .skeleton-date { width: 30%; }
    .skeleton-text { width: 100%; }
    .skeleton-text.short { width: 60%; }
</style>
{% endblock %}

{% block nav_links %}
<li><a href="{{ path_prefix }}{{ blog_page }}">Blog</a></li>
<li><a href="{{ path_prefix }}{{ summaries_page }}">Summaries</a></li>
<li><a href="{{ path_prefix }}{{ rss_file }}">RSS</a></li>
{% if x_account %}<li><a href="https://x.com/{{ x_account }}" target="_blank" rel="noopener">@{{ x_account }}</a></li>{% endif %}
{% endblock %}

{% block mobile_nav_links %}
<a href="{{ path_prefix }}{{ show_page }}" onclick="document.getElementById('mobileMenu').classList.remove('open')">Home</a>
<a href="{{ path_prefix }}{{ blog_page }}" onclick="document.getElementById('mobileMenu').classList.remove('open')">Blog</a>
<a href="{{ path_prefix }}{{ summaries_page }}" onclick="document.getElementById('mobileMenu').classList.remove('open')">Summaries</a>
<a href="#episodes" onclick="document.getElementById('mobileMenu').classList.remove('open')">Episodes</a>
<a href="#about" onclick="document.getElementById('mobileMenu').classList.remove('open')">About</a>
<a href="#resources" onclick="document.getElementById('mobileMenu').classList.remove('open')">Resources</a>
<a href="#faq" onclick="document.getElementById('mobileMenu').classList.remove('open')">FAQ</a>
{% endblock %}

{% block content %}
    <!-- Hero -->
    <section class="show-hero">
        <div class="show-hero-bg"></div>
        <div class="show-hero-inner">
            {% set _base = podcast_image_url[:-4] if podcast_image_url.endswith('.jpg') else podcast_image_url %}
            <picture>
                <source type="image/webp" srcset="{{ path_prefix }}{{ _base }}-400.webp 400w, {{ path_prefix }}{{ _base }}-800.webp 800w, {{ path_prefix }}{{ _base }}.webp 1400w" sizes="(max-width: 600px) 240px, 360px">
                <img src="{{ path_prefix }}{{ podcast_image_url }}" alt="{{ show_name }} cover art" class="show-hero-art"
                     width="1400" height="1400" fetchpriority="high"
                     onerror="this.style.display='none'">
            </picture>
            <div class="show-hero-info">
                <h1>{{ show_name }}</h1>
                <p class="show-hero-tagline">{{ hero_tagline }}</p>
                <div style="display:flex;gap:var(--sp-2);align-items:center;margin-bottom:var(--sp-3);font-family:var(--font-ui);font-size:0.85rem;color:var(--nn-text-muted);">
                    <span style="background:var(--nn-card);border:1px solid var(--nn-border);padding:2px 10px;border-radius:6px;">{{ schedule | default('Daily') }}</span>
                    {% if episode_length %}<span style="background:var(--nn-card);border:1px solid var(--nn-border);padding:2px 10px;border-radius:6px;">{{ episode_length }}</span>{% endif %}
                </div>
                <p class="show-hero-desc">{{ show_description }}</p>
                {% if audience %}
                <p style="font-family:var(--font-ui);font-size:0.88rem;color:var(--nn-text-muted);margin-bottom:var(--sp-4);font-style:italic;">{{ audience }}</p>
                {% endif %}
                <div class="show-hero-actions">
                    <a href="#episodes" class="nn-btn nn-btn-primary">Listen Now</a>
                    <a href="{{ path_prefix }}{{ blog_page }}" class="nn-btn">Read Blog</a>
                    <a href="{{ path_prefix }}{{ summaries_page }}" class="nn-btn">View Summaries</a>
                    {% if apple_podcasts_url %}
                    <a href="{{ apple_podcasts_url | with_utm(campaign=show_slug) }}" class="nn-btn" target="_blank" rel="noopener" data-show="{{ show_slug }}">Apple Podcasts</a>
                    {% endif %}
                    {% if spotify_url %}
                    <a href="{{ spotify_url | with_utm(campaign=show_slug) }}" class="nn-btn" target="_blank" rel="noopener" data-show="{{ show_slug }}">Spotify</a>
                    {% endif %}
                    <a href="{{ path_prefix }}{{ rss_file }}" class="nn-btn" data-show="{{ show_slug }}">RSS Feed</a>
                    {% if x_account %}
                    <a href="https://x.com/{{ x_account }}" class="nn-btn" target="_blank" rel="noopener">@{{ x_account }}</a>
                    {% endif %}
                </div>
                {% if show_slug == 'tesla' %}
                <div class="stock-widget" id="stock-widget">
                    <span class="ticker">TSLA</span>
                    <span class="price" id="stock-price">--</span>
                    <span class="change" id="stock-change">--</span>
                </div>
                {% endif %}
            </div>
        </div>
    </section>

    <!-- Latest Episode -->
    <section class="nn-section" style="padding-top: var(--sp-8);">
        <div class="container">
            <div class="latest-episode glass-card" id="latest-player">
                <div class="latest-episode-label">Latest Episode</div>
                <div class="latest-episode-title" id="latest-title">Loading...</div>
                <div class="latest-episode-date" id="latest-date"></div>
                <audio id="latest-audio" controls preload="none" aria-label="Latest episode audio player" style="width:100%;height:42px;border-radius:8px;"></audio>
                <div id="latest-summary" style="margin-top:var(--sp-4);color:var(--nn-text-muted);font-size:0.92rem;display:none;"></div>
            </div>
        </div>
    </section>

    {% if performance_data and performance_data.available %}
    <!-- Modern Investing — Mock Trade Performance vs NASDAQ -->
    <section class="nn-section" id="performance" style="padding-top: var(--sp-8);">
        <div class="container">
            <div class="nn-section-header" style="text-align:left;">
                <h2>Performance vs NASDAQ Composite</h2>
                <p style="color:var(--nn-text-muted);font-size:0.92rem;margin-top:var(--sp-2);">
                    Every Practice Investment from the show is tracked here. Simulated trades only — no real money.
                    Benchmark: NASDAQ Composite (^IXIC). Updated daily after each episode.
                </p>
            </div>

            <!-- Summary cards -->
            <div class="performance-summary-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:var(--sp-4);margin-bottom:var(--sp-6);">
                <div class="glass-card" style="padding:var(--sp-4);">
                    <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--nn-text-muted);">NASDAQ ^IXIC</div>
                    <div style="font-size:1.5rem;font-weight:700;margin-top:var(--sp-1);">
                        {% if performance_data.benchmark.current_close %}{{ "{:,.0f}".format(performance_data.benchmark.current_close) }}{% else %}—{% endif %}
                    </div>
                    <div style="font-size:0.85rem;color:var(--nn-text-muted);margin-top:var(--sp-1);">
                        YTD
                        {% if performance_data.benchmark.ytd_pct is not none %}{{ "{:+.2f}".format(performance_data.benchmark.ytd_pct) }}%{% else %}—{% endif %}
                    </div>
                </div>
                <div class="glass-card" style="padding:var(--sp-4);">
                    <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--nn-text-muted);">Portfolio YTD</div>
                    <div style="font-size:1.5rem;font-weight:700;margin-top:var(--sp-1);">
                        {% set p_ytd = (performance_data.alpha.ytd_pct or 0) + (performance_data.benchmark.ytd_pct or 0) %}
                        {{ "{:+.2f}".format(p_ytd) }}%
                    </div>
                    <div style="font-size:0.85rem;color:var(--nn-text-muted);margin-top:var(--sp-1);">
                        Since inception
                        {% set p_itd = (performance_data.alpha.inception_to_date_pct or 0) + (performance_data.benchmark.inception_to_date_pct or 0) %}
                        {{ "{:+.2f}".format(p_itd) }}%
                    </div>
                </div>
                <div class="glass-card" style="padding:var(--sp-4);">
                    <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--nn-text-muted);">Alpha vs NASDAQ</div>
                    {% set alpha_ytd = performance_data.alpha.ytd_pct or 0 %}
                    <div style="font-size:1.5rem;font-weight:700;margin-top:var(--sp-1);color:{% if alpha_ytd >= 0 %}#10b981{% else %}#ef4444{% endif %};">
                        {{ "{:+.2f}".format(alpha_ytd) }}% YTD
                    </div>
                    <div style="font-size:0.85rem;color:var(--nn-text-muted);margin-top:var(--sp-1);">
                        Since inception {{ "{:+.2f}".format(performance_data.alpha.inception_to_date_pct or 0) }}%
                    </div>
                </div>
                <div class="glass-card" style="padding:var(--sp-4);">
                    <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--nn-text-muted);">Win rate</div>
                    <div style="font-size:1.5rem;font-weight:700;margin-top:var(--sp-1);">
                        {{ "{:.0f}".format(performance_data.summary.win_rate_pct or 0) }}%
                    </div>
                    <div style="font-size:0.85rem;color:var(--nn-text-muted);margin-top:var(--sp-1);">
                        {{ performance_data.summary.wins or 0 }}W / {{ performance_data.summary.losses or 0 }}L /
                        {{ performance_data.summary.breakeven or 0 }}BE
                    </div>
                </div>
            </div>

            <!-- All trades table -->
            <div class="glass-card" style="padding:0;overflow-x:auto;margin-bottom:var(--sp-6);">
                <div style="padding:var(--sp-4);border-bottom:1px solid var(--nn-border);font-weight:600;">
                    All mock trades ({{ performance_data.trades|length }})
                </div>
                <table style="width:100%;border-collapse:collapse;font-size:0.88rem;">
                    <thead style="background:rgba(255,255,255,0.03);">
                        <tr style="text-align:left;">
                            <th style="padding:8px 12px;">Date</th>
                            <th style="padding:8px 12px;">Ep</th>
                            <th style="padding:8px 12px;">Ticker</th>
                            <th style="padding:8px 12px;">Sector</th>
                            <th style="padding:8px 12px;">Strategy</th>
                            <th style="padding:8px 12px;text-align:right;">Entry</th>
                            <th style="padding:8px 12px;text-align:right;">Exit</th>
                            <th style="padding:8px 12px;text-align:right;">P&amp;L %</th>
                            <th style="padding:8px 12px;text-align:right;">NASDAQ %</th>
                            <th style="padding:8px 12px;text-align:right;">Alpha %</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for t in performance_data.trades %}
                        <tr style="border-top:1px solid var(--nn-border);">
                            <td style="padding:6px 12px;">{{ t.date or "" }}</td>
                            <td style="padding:6px 12px;">{{ t.episode_num or "" }}</td>
                            <td style="padding:6px 12px;font-weight:600;">{{ t.symbol or "" }}</td>
                            <td style="padding:6px 12px;color:var(--nn-text-muted);font-size:0.82rem;">{{ t.sector or "" }}</td>
                            <td style="padding:6px 12px;max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{ t.strategy or '' }}">{{ t.strategy or "" }}</td>
                            <td style="padding:6px 12px;text-align:right;font-variant-numeric:tabular-nums;">{% if t.entry_price %}${{ "{:.2f}".format(t.entry_price) }}{% else %}—{% endif %}</td>
                            <td style="padding:6px 12px;text-align:right;font-variant-numeric:tabular-nums;">{% if t.exit_price %}${{ "{:.2f}".format(t.exit_price) }}{% else %}—{% endif %}</td>
                            <td style="padding:6px 12px;text-align:right;font-variant-numeric:tabular-nums;color:{% if (t.pnl_pct or 0) >= 0 %}#10b981{% else %}#ef4444{% endif %};">{% if t.pnl_pct is not none %}{{ "{:+.2f}".format(t.pnl_pct) }}%{% else %}—{% endif %}</td>
                            <td style="padding:6px 12px;text-align:right;font-variant-numeric:tabular-nums;color:var(--nn-text-muted);">{% if t.nasdaq_return_pct is not none %}{{ "{:+.2f}".format(t.nasdaq_return_pct) }}%{% else %}—{% endif %}</td>
                            <td style="padding:6px 12px;text-align:right;font-variant-numeric:tabular-nums;font-weight:600;color:{% if (t.alpha_pct or 0) >= 0 %}#10b981{% else %}#ef4444{% endif %};">{% if t.alpha_pct is not none %}{{ "{:+.2f}".format(t.alpha_pct) }}%{% else %}—{% endif %}</td>
                        </tr>
                        {% endfor %}
                        {% if not performance_data.trades %}
                        <tr><td colspan="10" style="padding:20px;text-align:center;color:var(--nn-text-muted);">No trades recorded yet.</td></tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>

            {% if performance_data.monthly_snapshots %}
            <!-- Monthly snapshots -->
            <div class="glass-card" style="padding:0;overflow-x:auto;margin-bottom:var(--sp-6);">
                <div style="padding:var(--sp-4);border-bottom:1px solid var(--nn-border);font-weight:600;">
                    Monthly performance snapshots
                </div>
                <table style="width:100%;border-collapse:collapse;font-size:0.88rem;">
                    <thead style="background:rgba(255,255,255,0.03);">
                        <tr style="text-align:left;">
                            <th style="padding:8px 12px;">Month</th>
                            <th style="padding:8px 12px;text-align:right;">Trades</th>
                            <th style="padding:8px 12px;text-align:right;">Win %</th>
                            <th style="padding:8px 12px;text-align:right;">Portfolio %</th>
                            <th style="padding:8px 12px;text-align:right;">NASDAQ %</th>
                            <th style="padding:8px 12px;text-align:right;">Alpha %</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for m in performance_data.monthly_snapshots %}
                        <tr style="border-top:1px solid var(--nn-border);">
                            <td style="padding:6px 12px;font-weight:600;">{{ m.month }}</td>
                            <td style="padding:6px 12px;text-align:right;">{{ m.trades or 0 }}</td>
                            <td style="padding:6px 12px;text-align:right;">{{ "{:.0f}".format(m.win_rate or 0) }}%</td>
                            <td style="padding:6px 12px;text-align:right;font-variant-numeric:tabular-nums;">{% if m.portfolio_pct is not none %}{{ "{:+.2f}".format(m.portfolio_pct) }}%{% else %}—{% endif %}</td>
                            <td style="padding:6px 12px;text-align:right;font-variant-numeric:tabular-nums;color:var(--nn-text-muted);">{% if m.nasdaq_pct is not none %}{{ "{:+.2f}".format(m.nasdaq_pct) }}%{% else %}—{% endif %}</td>
                            <td style="padding:6px 12px;text-align:right;font-variant-numeric:tabular-nums;font-weight:600;color:{% if (m.alpha_pct or 0) >= 0 %}#10b981{% else %}#ef4444{% endif %};">{% if m.alpha_pct is not none %}{{ "{:+.2f}".format(m.alpha_pct) }}%{% else %}—{% endif %}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}

            <!-- Recursive improvement rules -->
            <div class="glass-card" style="padding:var(--sp-4);">
                <div style="font-weight:600;margin-bottom:var(--sp-3);">
                    How this show improves itself
                    <span style="font-weight:normal;font-size:0.82rem;color:var(--nn-text-muted);margin-left:var(--sp-2);">
                        ({{ performance_data.lessons_learned|length }} active rules — each one was written by a past episode and is obeyed by future episodes)
                    </span>
                </div>
                {% if performance_data.lessons_learned %}
                <ul style="margin:0;padding-left:var(--sp-5);font-size:0.92rem;line-height:1.7;">
                    {% for e in performance_data.lessons_learned %}
                    <li style="margin-bottom:var(--sp-2);">
                        <span style="font-family:monospace;color:var(--nn-text-muted);font-size:0.82rem;">{{ e.id }}</span>
                        <em style="color:var(--nn-text-muted);">[{{ e.category }}, Ep{{ e.episode_num }}, {{ e.date }}]</em>
                        — {{ e.observation }}
                        <br>
                        <strong>Rule:</strong> {{ e.adjustment }}
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <p style="color:var(--nn-text-muted);font-size:0.92rem;">No active rules yet — the daily show will append one each episode when a trade teaches a generalisable lesson.</p>
                {% endif %}
            </div>

            <p style="color:var(--nn-text-muted);font-size:0.78rem;margin-top:var(--sp-4);">
                SIMULATED trades for educational purposes only. No real money is involved. This is NOT financial advice.
            </p>
        </div>
    </section>
    {% endif %}

    <!-- Episode Archive -->
    <section id="episodes" class="nn-section" style="padding-top: 0;">
        <div class="container">
            <div class="nn-section-header" style="text-align:left;">
                <h2>Recent Episodes</h2>
            </div>
            <div id="episodes-grid" class="episodes-grid">
                {% if static_episodes %}
                {% for ep in static_episodes %}
                <div class="episode-card glass-card">
                    <div class="episode-card-title">{{ ep.title }}</div>
                    <div class="episode-card-date">{{ ep.date_display }}</div>
                    {% if ep.audio_url %}
                    <audio controls preload="none" src="{{ ep.audio_url }}" style="width:100%;height:36px;border-radius:8px;margin-top:var(--sp-2);"></audio>
                    {% endif %}
                </div>
                {% endfor %}
                {% else %}
                <div class="skeleton-card"><div class="skeleton-line skeleton-title"></div><div class="skeleton-line skeleton-date"></div><div class="skeleton-line skeleton-text"></div><div class="skeleton-line skeleton-text short"></div></div>
                <div class="skeleton-card"><div class="skeleton-line skeleton-title"></div><div class="skeleton-line skeleton-date"></div><div class="skeleton-line skeleton-text"></div><div class="skeleton-line skeleton-text short"></div></div>
                <div class="skeleton-card"><div class="skeleton-line skeleton-title"></div><div class="skeleton-line skeleton-date"></div><div class="skeleton-line skeleton-text"></div><div class="skeleton-line skeleton-text short"></div></div>
                {% endif %}
            </div>
            <div style="text-align:center;margin-top:var(--sp-6);">
                <a href="{{ path_prefix }}{{ summaries_page }}" class="nn-btn">View All Episodes</a>
            </div>
        </div>
    </section>

    <!-- About -->
    <section id="about" class="nn-section" style="border-top:1px solid var(--nn-border);">
        <div class="container">
            <div class="nn-section-header">
                <h2>About {{ show_name }}</h2>
            </div>
            <div class="about-section-text">
                <p>{{ about_text }}</p>
                {% if about_host %}
                <p>{{ about_host }}</p>
                {% endif %}
            </div>
        </div>
    </section>

    <!-- Resources (categorized) -->
    {% if resource_categories %}
    <section id="resources" class="nn-section" style="padding-top:0;">
        <div class="container">
            <div class="nn-section-header" style="text-align:left;">
                <h2>Resources &amp; Further Reading</h2>
            </div>
            {% for cat in resource_categories %}
            <div class="resource-category">
                <h3 class="resource-category-title">{{ cat.title }}</h3>
                <div class="resources-grid">
                    {% for r in cat.resources %}
                    <a href="{{ r.url }}" class="resource-card glass-card" target="_blank" rel="noopener">
                        <div class="resource-card-name">{{ r.name }}</div>
                        <div class="resource-card-desc">{{ r.desc }}</div>
                        <div class="resource-card-url">{{ r.url | replace('https://', '') | replace('http://', '') }}</div>
                    </a>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>
    </section>
    {% elif resources %}
    <!-- Fallback: flat resources grid (legacy) -->
    <section id="resources" class="nn-section" style="padding-top:0;">
        <div class="container">
            <div class="nn-section-header" style="text-align:left;">
                <h2>Resources &amp; Further Reading</h2>
            </div>
            <div class="resources-grid">
                {% for r in resources %}
                <a href="{{ r.url }}" class="resource-card glass-card" target="_blank" rel="noopener">
                    <div class="resource-card-name">{{ r.name }}</div>
                    <div class="resource-card-desc">{{ r.desc }}</div>
                    <div class="resource-card-url">{{ r.url | replace('https://', '') | replace('http://', '') }}</div>
                </a>
                {% endfor %}
            </div>
        </div>
    </section>
    {% endif %}

    <!-- Recommended Tools -->
    {% if tools %}
    <section class="nn-section" style="padding-top:0;">
        <div class="container">
            <div class="nn-section-header" style="text-align:left;">
                <h2>Recommended Tools</h2>
            </div>
            <div class="tools-grid">
                {% for t in tools %}
                <a href="{{ t.url }}" class="tool-card glass-card" target="_blank" rel="noopener">
                    {% if t.badge %}<span class="tool-badge">{{ t.badge }}</span>{% endif %}
                    <div class="tool-card-name">{{ t.name }}</div>
                    <div class="tool-card-desc">{{ t.desc }}</div>
                </a>
                {% endfor %}
            </div>
        </div>
    </section>
    {% endif %}

    <!-- Referral -->
    {% if referral %}
    <section id="referral" class="nn-section" style="padding-top:0;">
        <div class="container" style="max-width:800px;">
            <div class="referral-card glass-card" style="padding:var(--sp-8);border-color:color-mix(in srgb, var(--show-color) 35%, var(--nn-border));">
                <div style="text-align:center;margin-bottom:var(--sp-6);">
                    <div style="font-size:2.2rem;margin-bottom:var(--sp-2);">&#9889;</div>
                    <h2 style="font-family:var(--font-heading);font-size:1.5rem;font-weight:700;color:var(--nn-white);margin-bottom:var(--sp-3);">{{ referral.heading }}</h2>
                    <p style="color:var(--nn-text-muted);font-size:0.95rem;line-height:1.7;max-width:600px;margin:0 auto;">{{ referral.intro }}</p>
                </div>

                <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));gap:var(--sp-6);margin-bottom:var(--sp-6);">
                    <div>
                        <h3 style="font-family:var(--font-heading);font-size:1rem;font-weight:600;color:var(--show-color);margin-bottom:var(--sp-3);">Vehicle Benefits</h3>
                        <ul style="list-style:none;padding:0;margin:0;">
                            {% for b in referral.buyer_benefits %}
                            <li style="font-family:var(--font-ui);font-size:0.9rem;color:var(--nn-text-muted);line-height:1.6;padding:var(--sp-1) 0;padding-left:1.4em;position:relative;"><span style="position:absolute;left:0;color:var(--show-color);">&#10003;</span>{{ b }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                    {% if referral.energy_benefits %}
                    <div>
                        <h3 style="font-family:var(--font-heading);font-size:1rem;font-weight:600;color:var(--show-color);margin-bottom:var(--sp-3);">Energy Products</h3>
                        <ul style="list-style:none;padding:0;margin:0;">
                            {% for b in referral.energy_benefits %}
                            <li style="font-family:var(--font-ui);font-size:0.9rem;color:var(--nn-text-muted);line-height:1.6;padding:var(--sp-1) 0;padding-left:1.4em;position:relative;"><span style="position:absolute;left:0;color:var(--show-color);">&#10003;</span>{{ b }}</li>
