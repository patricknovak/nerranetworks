{% extends "base.html.j2" %}

{% block head_extra %}
    <style>
        .error-page {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 60vh;
            text-align: center;
            padding: var(--sp-12) var(--sp-6);
        }
        .error-code {
            font-family: var(--font-heading);
            font-size: clamp(4rem, 10vw, 8rem);
            font-weight: 700;
            background: linear-gradient(135deg, var(--nn-purple), var(--nn-cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
            margin-bottom: var(--sp-4);
        }
        .error-page h1 {
            font-family: var(--font-heading);
            font-size: clamp(1.2rem, 3vw, 1.6rem);
            font-weight: 600;
            color: var(--nn-white);
            margin: 0 0 var(--sp-4);
        }
        .error-page p {
            font-family: var(--font-body);
            font-size: 1rem;
            color: var(--nn-text-muted);
            line-height: 1.6;
            max-width: 420px;
            margin: 0 0 var(--sp-8);
        }
        .error-links {
            display: flex;
            flex-wrap: wrap;
            gap: var(--sp-3);
            justify-content: center;
        }
        .error-links a {
            display: inline-flex;
            align-items: center;
            gap: var(--sp-2);
            padding: var(--sp-3) var(--sp-6);
            border-radius: 100px;
            font-family: var(--font-ui);
            font-size: 0.9rem;
            font-weight: 500;
            text-decoration: none;
            transition: all var(--duration) var(--ease);
        }
        .error-links .primary {
            background: linear-gradient(135deg, var(--nn-purple), var(--nn-cyan));
            color: #fff;
        }
        .error-links .primary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }
        .error-links .secondary {
            border: 1px solid var(--nn-border);
            color: var(--nn-text-muted);
        }
        .error-links .secondary:hover {
            border-color: var(--nn-purple);
            color: var(--nn-white);
        }
    </style>
{% endblock %}

{% block content %}
    <main class="error-page">
        <div class="error-code">404</div>
        <h1>Page not found</h1>
        <p>The page you're looking for doesn't exist or has been moved. Try one of these instead:</p>
        <div class="error-links">
            <a href="{{ path_prefix }}index.html" class="primary">Go Home</a>
            <a href="{{ path_prefix }}blog/index.html" class="secondary">Browse Blog</a>
        </div>
    </main>
{% endblock %}
