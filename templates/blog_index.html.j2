{% extends "base.html.j2" %}

{% block head_extra %}
    <link rel="alternate" type="application/rss+xml" title="{{ show_name }} Blog RSS" href="{{ blog_rss_url }}">

    <style>
        .blog-idx-hero {
            position: relative;
            padding: var(--sp-20) var(--sp-6) var(--sp-12);
            text-align: center;
            overflow: hidden;
        }
        .blog-idx-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 0%, color-mix(in srgb, var(--show-color) 15%, transparent), transparent 70%);
            pointer-events: none;
        }
        .blog-idx-hero-inner {
            position: relative;
            max-width: 680px;
            margin: 0 auto;
        }
        .blog-idx-cover {
            width: 80px;
            height: 80px;
            border-radius: 18px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            margin-bottom: var(--sp-6);
        }
        .blog-idx-hero h1 {
            font-family: var(--font-heading);
            font-size: clamp(1.5rem, 3.5vw, 2.2rem);
            font-weight: 700;
            color: var(--nn-white);
            margin: 0 0 var(--sp-3);
        }
        .blog-idx-hero p {
            font-family: var(--font-body);
            font-size: 1.05rem;
            color: var(--nn-text-muted);
            line-height: 1.6;
            margin: 0 0 var(--sp-6);
        }
        .blog-rss-btn {
            display: inline-flex;
            align-items: center;
            gap: var(--sp-2);
            padding: var(--sp-2) var(--sp-5);
            border-radius: 100px;
            background: color-mix(in srgb, var(--show-color) 12%, transparent);
            border: 1px solid color-mix(in srgb, var(--show-color) 30%, transparent);
            color: var(--show-color);
            font-family: var(--font-ui);
            font-size: 0.85rem;
            font-weight: 500;
            text-decoration: none;
            transition: all var(--duration) var(--ease);
        }
        .blog-rss-btn:hover {
            background: color-mix(in srgb, var(--show-color) 20%, transparent);
            border-color: var(--show-color);
        }
    </style>
{% endblock %}

{% block content %}
    <!-- Hero -->
    <header class="blog-idx-hero">
        <div class="blog-idx-hero-inner">
            {% if podcast_image %}
            <img src="{{ path_prefix }}{{ podcast_image }}" alt="{{ show_name }} cover art" class="blog-idx-cover" width="1400" height="1400">
            {% endif %}
            <h1>{{ show_name }} Blog</h1>
            <p>{{ description }}</p>
            <a href="{{ blog_rss_url }}" class="blog-rss-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
                Subscribe via RSS
            </a>
        </div>
    </header>

    <!-- Posts -->
    {% if posts %}
    <div class="blog-idx-grid">
        {% for post in posts %}
        <a href="ep{{ '%03d' % post.episode_num }}.html" class="blog-idx-card">
            <div class="blog-idx-card-top">
                <span class="blog-idx-date">{{ post.date }}</span>
                <span class="blog-idx-ep">Ep {{ post.episode_num }}</span>
                <span class="blog-idx-reading">{{ post.reading_time_min }} min</span>
            </div>
            <h2>{{ post.title }}{% if post.title == show_name %} — Ep {{ post.episode_num }}{% endif %}</h2>
            {% if post.hook %}
            <p>{{ post.hook[:160] }}{% if post.hook|length > 160 %}&hellip;{% endif %}</p>
            {% endif %}
            <span class="blog-idx-read-more">Read article &rarr;</span>
        </a>
        {% endfor %}
    </div>
    {% else %}
    <div class="blog-idx-empty">
        <p>No blog posts yet. Check back soon!</p>
    </div>
    {% endif %}
{% endblock %}
