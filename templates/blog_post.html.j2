{% extends "base.html.j2" %}

{% block og_type %}article{% endblock %}

{% block head_extra %}
    <!-- Blog Post OG -->
    <meta property="article:published_time" content="{{ episode_date_iso }}">
    <meta property="article:author" content="{{ show_name }}">

    <!-- JSON-LD -->
    <script type="application/ld+json">
{{ jsonld }}
    </script>
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://nerranetwork.com/"},
    {"@type": "ListItem", "position": 2, "name": "{{ show_name }}", "item": "https://nerranetwork.com/{{ show_page }}"},
    {"@type": "ListItem", "position": 3, "name": "Blog", "item": "https://nerranetwork.com/blog/{{ show_slug }}/index.html"},
    {"@type": "ListItem", "position": 4, "name": "Episode {{ episode_num }}"}
  ]
}
    </script>

    <style>
        .blog-hero {
            position: relative;
            padding: var(--sp-20) var(--sp-6) var(--sp-12);
            text-align: center;
            overflow: hidden;
        }
        .blog-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 0%, color-mix(in srgb, var(--show-color) 15%, transparent), transparent 70%);
            pointer-events: none;
        }
        .blog-hero-inner {
            position: relative;
            max-width: 760px;
            margin: 0 auto;
        }
        .blog-show-badge {
            display: inline-flex;
            align-items: center;
            gap: var(--sp-2);
            padding: var(--sp-1) var(--sp-4);
            border-radius: 100px;
            background: var(--nn-card);
            border: 1px solid var(--nn-border);
            font-family: var(--font-ui);
            font-size: 0.85rem;
            color: var(--nn-text-muted);
            margin-bottom: var(--sp-6);
            text-decoration: none;
            transition: border-color var(--duration) var(--ease);
        }
        .blog-show-badge:hover {
            border-color: var(--show-color);
        }
        .blog-show-badge img {
            width: 24px;
            height: 24px;
            border-radius: 6px;
        }
        .blog-hero h1 {
            font-family: var(--font-heading);
            font-size: clamp(1.75rem, 4vw, 2.5rem);
            font-weight: 700;
            line-height: 1.2;
            color: var(--nn-white);
            margin: 0 0 var(--sp-5);
        }
        .blog-hero-hook {
            font-family: var(--font-body);
            font-size: 1.15rem;
            line-height: 1.6;
            color: var(--nn-text-muted);
            max-width: 620px;
            margin: 0 auto var(--sp-8);
        }
        .blog-meta-bar {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: var(--sp-5);
            flex-wrap: wrap;
            font-family: var(--font-ui);
            font-size: 0.85rem;
            color: var(--nn-text-muted);
        }
        .blog-meta-bar span {
            display: inline-flex;
            align-items: center;
            gap: var(--sp-1);
        }
        .blog-meta-pill {
            padding: 2px 10px;
            border-radius: 100px;
            background: color-mix(in srgb, var(--show-color) 15%, transparent);
            color: var(--show-color);
            font-weight: 600;
        }
        .post-author {
            color: var(--nn-text-muted);
            font-size: 0.875rem;
        }

        /* Share buttons */
        .share-buttons {
            display: flex;
            align-items: center;
            gap: var(--sp-3);
            margin-top: var(--sp-10);
            padding-top: var(--sp-6);
            border-top: 1px solid var(--nn-border);
            font-family: var(--font-ui);
            font-size: 0.9rem;
            color: var(--nn-text-muted);
            flex-wrap: wrap;
        }
        .share-buttons a,
        .share-buttons button {
            display: inline-flex;
            align-items: center;
            gap: var(--sp-1);
            padding: var(--sp-2) var(--sp-4);
            border-radius: 8px;
            border: 1px solid var(--nn-border);
            background: var(--nn-card);
            color: var(--nn-text-muted);
            font-family: var(--font-ui);
            font-size: 0.85rem;
            text-decoration: none;
            cursor: pointer;
            transition: all var(--duration) var(--ease);
        }
        .share-buttons a:hover,
        .share-buttons button:hover {
            border-color: var(--show-color);
            color: var(--nn-white);
        }

        /* Article body */
        .blog-article-wrap {
            max-width: 760px;
            margin: 0 auto;
            padding: 0 var(--sp-6) var(--sp-16);
            display: grid;
            grid-template-columns: 1fr;
            gap: var(--sp-10);
        }
        @media (min-width: 1024px) {
            .blog-article-wrap {
                max-width: 1060px;
                grid-template-columns: 200px 1fr;
            }
        }

        /* Table of contents */
        .blog-toc {
            display: none;
        }
        @media (min-width: 1024px) {
            .blog-toc {
                display: block;
                position: sticky;
                top: calc(var(--nav-height) + var(--sp-8));
                align-self: start;
                max-height: calc(100vh - var(--nav-height) - var(--sp-16));
                overflow-y: auto;
                padding-right: var(--sp-4);
            }
        }
        .blog-toc-title {
            font-family: var(--font-ui);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--nn-text-muted);
            margin-bottom: var(--sp-3);
            font-weight: 600;
        }
        .blog-toc a {
            display: block;
            padding: var(--sp-1) 0;
            font-family: var(--font-ui);
            font-size: 0.8rem;
            color: var(--nn-text-muted);
            text-decoration: none;
            border-left: 2px solid transparent;
            padding-left: var(--sp-3);
            transition: all var(--duration) var(--ease);
            line-height: 1.4;
        }
        .blog-toc a:hover,
        .blog-toc a.active {
            color: var(--show-color);
            border-left-color: var(--show-color);
        }
        .blog-toc a.toc-h3 {
            padding-left: var(--sp-6);
            font-size: 0.75rem;
        }

        /* Article */
        .blog-article {
            min-width: 0;
        }
        .blog-article h1 {
            font-family: var(--font-heading);
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--nn-white);
            margin: var(--sp-10) 0 var(--sp-4);
            padding-left: var(--sp-4);
            border-left: 3px solid var(--show-color);
        }
        .blog-article h2 {
            font-family: var(--font-heading);
            font-size: 1.35rem;
            font-weight: 600;
            color: var(--nn-white);
            margin: var(--sp-10) 0 var(--sp-4);
            padding-left: var(--sp-4);
            border-left: 3px solid var(--show-color);
        }
        .blog-article h3 {
            font-family: var(--font-heading);
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--nn-text);
            margin: var(--sp-8) 0 var(--sp-3);
        }
        .blog-article p {
            font-family: var(--font-body);
            font-size: 1.05rem;
            line-height: 1.8;
            color: var(--nn-text);
            margin: 0 0 var(--sp-4);
        }
        .blog-article a {
            color: var(--show-color);
            text-decoration: underline;
            text-underline-offset: 2px;
            text-decoration-color: color-mix(in srgb, var(--show-color) 40%, transparent);
            transition: text-decoration-color var(--duration) var(--ease);
        }
        .blog-article a:hover {
            text-decoration-color: var(--show-color);
        }
        .blog-article strong {
            color: var(--nn-white);
            font-weight: 600;
        }
        .blog-article ul,
        .blog-article ol {
            margin: 0 0 var(--sp-6);
            padding-left: var(--sp-6);
        }
        .blog-article li {
            font-family: var(--font-body);
            font-size: 1.05rem;
            line-height: 1.8;
            color: var(--nn-text);
            margin-bottom: var(--sp-3);
        }
        .blog-article .blog-list-cont {
            margin: var(--sp-1) 0 var(--sp-2);
            padding-left: var(--sp-2);
            font-size: 1rem;
            color: var(--nn-text-muted);
        }
        .blog-article hr {
            border: none;
            border-top: 1px solid var(--nn-border);
            margin: var(--sp-10) 0;
        }
        .blog-article pre {
            background: var(--nn-card);
            border: 1px solid var(--nn-border);
            border-radius: 8px;
            padding: var(--sp-4);
            margin: 0 0 var(--sp-6);
            overflow-x: auto;
        }
        .blog-article pre > code {
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            font-size: 0.9rem;
            line-height: 1.6;
            color: var(--nn-text);
            background: none;
            padding: 0;
            border: none;
            border-radius: 0;
        }
        .blog-article code {
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            font-size: 0.88em;
            background: color-mix(in srgb, var(--nn-border) 50%, transparent);
            padding: 0.15em 0.4em;
            border-radius: 4px;
            color: var(--nn-white);
        }
        .blog-article blockquote {
            border-left: 3px solid var(--show-color);
            margin: 0 0 var(--sp-6);
            padding: var(--sp-3) var(--sp-6);
            background: color-mix(in srgb, var(--show-color) 5%, transparent);
            border-radius: 0 8px 8px 0;
        }
        .blog-article blockquote p {
            font-style: italic;
            color: var(--nn-text-muted);
            margin-bottom: var(--sp-2);
        }
        .blog-article blockquote p:last-child {
            margin-bottom: 0;
        }
        .blog-article h4 {
            font-family: var(--font-heading);
            font-size: 1rem;
            font-weight: 600;
            color: var(--nn-text);
            margin: var(--sp-6) 0 var(--sp-2);
        }

        /* Sources section */
        .blog-sources {
            margin-top: var(--sp-10);
            padding-top: var(--sp-8);
            border-top: 1px solid var(--nn-border);
        }
        .blog-sources h2 {
            border-left: none;
            padding-left: 0;
            font-size: 1.1rem;
            margin-bottom: var(--sp-4);
        }
        .blog-sources-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: var(--sp-3);
        }
        .blog-source-card {
            display: flex;
            align-items: center;
            gap: var(--sp-3);
            padding: var(--sp-3) var(--sp-4);
            background: var(--nn-card);
            border: 1px solid var(--nn-border);
            border-radius: 10px;
            text-decoration: none;
            transition: all var(--duration) var(--ease);
        }
        .blog-source-card:hover {
            border-color: var(--show-color);
            background: var(--nn-card-hover);
        }
        .blog-source-card .source-domain {
            font-family: var(--font-ui);
            font-size: 0.85rem;
            color: var(--nn-text);
            font-weight: 500;
        }
        .blog-source-card .source-icon {
            width: 20px;
            height: 20px;
            border-radius: 4px;
            background: var(--nn-surface);
            flex-shrink: 0;
        }

        /* Related posts */
        .blog-related {
            margin-top: var(--sp-10);
            padding-top: var(--sp-8);
            border-top: 1px solid var(--nn-border);
        }
        .blog-related h2 {
            border-left: none;
            padding-left: 0;
            font-size: 1.2rem;
            margin-bottom: var(--sp-4);
        }
        .blog-related-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: var(--sp-4);
        }
        .blog-related-card {
            display: flex;
            flex-direction: column;
            gap: var(--sp-2);
            padding: var(--sp-5);
            padding-left: calc(var(--sp-5) + 4px);
            background: var(--nn-card);
            border: 1px solid var(--nn-border);
            border-left: 4px solid var(--card-show-color, var(--nn-purple));
            border-radius: 12px;
            text-decoration: none;
            transition: all var(--duration) var(--ease);
        }
        .blog-related-card:hover {
            border-color: var(--card-show-color, var(--nn-purple));
            background: var(--nn-card-hover);
            transform: translateY(-2px);
        }
        .blog-related-show {
            font-family: var(--font-ui);
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .blog-related-card h3 {
            font-family: var(--font-heading);
            font-size: 1rem;
            font-weight: 600;
            color: var(--nn-white);
            margin: 0;
            line-height: 1.3;
        }
        .blog-related-card p {
            font-family: var(--font-body);
            font-size: 0.85rem;
            color: var(--nn-text-muted);
            margin: 0;
            line-height: 1.5;
        }

        /* Transcript */
        .blog-transcript {
            margin-top: var(--sp-8);
            padding-top: var(--sp-6);
            border-top: 1px solid var(--nn-border);
        }
        .blog-transcript details summary {
            display: flex;
            align-items: center;
            gap: var(--sp-2);
            font-family: var(--font-heading);
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--nn-white);
            cursor: pointer;
            padding: var(--sp-3) 0;
            list-style: none;
        }
        .blog-transcript details summary::-webkit-details-marker { display: none; }
        .blog-transcript details summary::after {
            content: '+';
            margin-left: auto;
            font-size: 1.2rem;
            color: var(--nn-text-muted);
        }
        .blog-transcript details[open] summary::after { content: '\2212'; }
        .blog-transcript .transcript-content {
            font-family: var(--font-body);
            font-size: 0.95rem;
            line-height: 1.8;
            color: var(--nn-text-muted);
            padding: var(--sp-4) 0;
            white-space: pre-wrap;
            max-height: 600px;
            overflow-y: auto;
        }

        /* Episode navigation */
        .blog-ep-nav {
            display: flex;
            justify-content: space-between;
            gap: var(--sp-4);
            margin-top: var(--sp-10);
            padding-top: var(--sp-8);
            border-top: 1px solid var(--nn-border);
        }
        .blog-ep-nav a {
            display: flex;
            flex-direction: column;
            gap: var(--sp-1);
            padding: var(--sp-4) var(--sp-5);
            background: var(--nn-card);
            border: 1px solid var(--nn-border);
            border-radius: 12px;
            text-decoration: none;
            transition: all var(--duration) var(--ease);
            max-width: 48%;
        }
        .blog-ep-nav a:hover {
            border-color: var(--show-color);
            background: var(--nn-card-hover);
        }
        .blog-ep-nav .nav-label {
            font-family: var(--font-ui);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--nn-text-muted);
        }
        .blog-ep-nav .nav-title {
            font-family: var(--font-ui);
            font-size: 0.9rem;
            color: var(--nn-text);
            font-weight: 500;
        }
        .blog-ep-nav .next {
            text-align: right;
            margin-left: auto;
        }

        /* Listen CTA */
        .blog-listen-cta {
            display: inline-flex;
            align-items: center;
            gap: var(--sp-2);
            padding: var(--sp-2) var(--sp-5);
            border-radius: 100px;
            background: var(--nn-card);
            border: 1px solid var(--nn-border);
            color: var(--nn-text-muted);
            font-family: var(--font-ui);
            font-size: 0.85rem;
            text-decoration: none;
            transition: all var(--duration) var(--ease);
        }
        .blog-listen-cta:hover {
            border-color: var(--show-color);
            color: var(--show-color);
        }
    </style>
{% endblock %}

{% block content %}
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" style="max-width:900px;margin:calc(72px + var(--sp-4)) auto 0;padding:0 var(--sp-6);font-family:var(--font-ui);font-size:0.82rem;">
        <ol style="list-style:none;display:flex;flex-wrap:wrap;gap:var(--sp-1);padding:0;margin:0;color:var(--nn-text-muted);">
            <li><a href="{{ path_prefix }}index.html" style="color:var(--nn-text-muted);text-decoration:none;">Home</a> <span aria-hidden="true">/</span></li>
            <li><a href="{{ path_prefix }}{{ show_page }}" style="color:var(--nn-text-muted);text-decoration:none;">{{ show_name }}</a> <span aria-hidden="true">/</span></li>
            <li><a href="{{ blog_index_url }}" style="color:var(--nn-text-muted);text-decoration:none;">Blog</a> <span aria-hidden="true">/</span></li>
            <li aria-current="page" style="color:var(--show-color);">Episode {{ episode_num }}</li>
        </ol>
    </nav>

    <!-- Hero -->
    <header class="blog-hero">
        <div class="blog-hero-inner">
            <a href="{{ blog_index_url }}" class="blog-show-badge">
                <picture><source type="image/webp" srcset="{{ path_prefix }}{{ podcast_image[:-4] if podcast_image.endswith('.jpg') else podcast_image }}-400.webp"><img src="{{ path_prefix }}{{ podcast_image }}" alt="{{ show_name }}" width="40" height="40"></picture>
                {{ show_name }} Blog
            </a>
            <h1>{{ episode_title }} — Episode {{ episode_num }}</h1>
            {% if hook %}
            <p class="blog-hero-hook">{{ hook }}</p>
            {% endif %}
            <div class="blog-meta-bar">
                <span class="post-author">By Patrick</span>
                <span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    {{ episode_date }}
                </span>
                <span class="blog-meta-pill">Ep {{ episode_num }}</span>
                <span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {{ reading_time_min }} min read
                </span>
                {% if show_page %}
                <a href="{{ path_prefix }}{{ show_page }}" class="blog-listen-cta">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    Listen to podcast
                </a>
                {% elif rss_file %}
                <a href="{{ path_prefix }}{{ rss_file }}" class="blog-listen-cta">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    Listen to podcast
                </a>
                {% endif %}
                {% if summaries_page %}
                <a href="{{ path_prefix }}{{ summaries_page }}" class="blog-listen-cta">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                    View summaries
                </a>
                {% endif %}
                {% if youtube_url %}
                <a href="{{ youtube_url }}" class="blog-listen-cta" rel="noopener" target="_blank">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
                    Watch on YouTube
                </a>
                {% endif %}
            </div>
        </div>
    </header>

    <!-- Article with TOC sidebar -->
    <div class="blog-article-wrap">
        {% if toc %}
        <aside class="blog-toc">
            <div class="blog-toc-title">Contents</div>
            {% for item in toc %}
            <a href="#{{ item.id }}" class="{% if item.level == 3 %}toc-h3{% endif %}">{{ item.text }}</a>
            {% endfor %}
        </aside>
        {% else %}
        <div></div>
        {% endif %}

        <article class="blog-article">
            {{ blog_body }}

            <!-- Sources -->
            {% if source_domains %}
            <section class="blog-sources">
                <h2>Sources</h2>
                <div class="blog-sources-grid">
                    {% for src in source_domains %}
                    <a href="{{ src.url }}" target="_blank" rel="noopener" class="blog-source-card">
                        <img src="https://www.google.com/s2/favicons?domain={{ src.domain }}&sz=32" alt="" class="source-icon" loading="lazy">
                        <span class="source-domain">{{ src.domain }}</span>
                    </a>
                    {% endfor %}
                </div>
            </section>
            {% endif %}

            <!-- Transcript -->
            {% if transcript %}
            <section class="blog-transcript">
                <details>
                    <summary>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h10"/></svg>
                        Full Episode Transcript
                    </summary>
                    <div class="transcript-content">{{ transcript }}</div>
                </details>
            </section>
            {% endif %}

            <!-- Share Buttons -->
            <div class="share-buttons">
                <span>Share:</span>
                <a href="https://twitter.com/intent/tweet?url={{ canonical_url }}&text={{ page_title | urlencode }}" target="_blank" rel="noopener" aria-label="Share on Twitter">&#120143; Post</a>
                <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ canonical_url }}" target="_blank" rel="noopener" aria-label="Share on LinkedIn">in LinkedIn</a>
                <button onclick="navigator.clipboard.writeText(window.location.href).then(function(){this.textContent='\u2713 Copied'}.bind(this))" aria-label="Copy link">&#128279; Copy link</button>
            </div>

            <!-- Subscribe CTA -->
            {% if newsletter_tag %}
            <div class="show-subscribe-inline" style="margin-top:var(--sp-6);margin-bottom:var(--sp-6);">
                <h3>Enjoy this episode? Get {{ show_name }} in your inbox</h3>
                <p>New episode alerts — no spam, unsubscribe anytime.</p>
                <form action="https://buttondown.com/api/emails/embed-subscribe/patricknovak1" method="post" target="popupwindow"
                      onsubmit="var btn=this.querySelector('button[type=submit]');btn.disabled=true;btn.textContent='Subscribing…';setTimeout(function(){btn.textContent='Check your email ✓';btn.disabled=false;},500);">
                    <input type="hidden" name="tag" value="{{ newsletter_tag }}">
                    <input type="hidden" value="1" name="embed">
                    <div class="nn-subscribe-row">
                        <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address">
                        <button type="submit">Subscribe</button>
                    </div>
                </form>
            </div>
            {% endif %}

            <!-- Episode Navigation -->
            {% if prev_post or next_post %}
            <nav class="blog-ep-nav">
                {% if prev_post %}
                <a href="ep{{ '%03d' % prev_post.episode_num }}.html" rel="prev">
                    <span class="nav-label">&larr; Previous</span>
                    <span class="nav-title">Episode {{ prev_post.episode_num }}</span>
                </a>
                {% else %}
                <div></div>
                {% endif %}
                {% if next_post %}
                <a href="ep{{ '%03d' % next_post.episode_num }}.html" rel="next" class="next">
                    <span class="nav-label">Next &rarr;</span>
                    <span class="nav-title">Episode {{ next_post.episode_num }}</span>
                </a>
                {% endif %}
            </nav>
            {% endif %}
            <!-- Cross-show Recommendations -->
            {% if related_posts %}
            <section class="blog-related">
                <h2>You Might Also Like</h2>
                <div class="blog-related-grid">
                    {% for rp in related_posts %}
                    <a href="{{ rp.url }}" class="blog-related-card" style="--card-show-color: {{ rp.show_color }}">
                        <span class="blog-related-show" style="color: {{ rp.show_color }}">{{ rp.show_name }}</span>
                        <h3>{{ rp.title }}</h3>
                        {% if rp.hook %}<p>{{ rp.hook[:120] }}{% if rp.hook|length > 120 %}&hellip;{% endif %}</p>{% endif %}
                    </a>
                    {% endfor %}
                </div>
            </section>
            {% endif %}
        </article>
    </div>
{% endblock %}

{% block scripts %}
<script>
// Highlight active TOC entry on scroll
(function() {
    const toc = document.querySelector('.blog-toc');
    if (!toc) return;
    const links = toc.querySelectorAll('a');
    const headings = [];
    links.forEach(function(a) {
        const id = a.getAttribute('href').slice(1);
        const el = document.getElementById(id);
        if (el) headings.push({ el: el, link: a });
    });
    if (!headings.length) return;
    function onScroll() {
        var current = headings[0];
        for (var i = 0; i < headings.length; i++) {
            if (headings[i].el.getBoundingClientRect().top <= 120) {
                current = headings[i];
            }
        }
        links.forEach(function(a) { a.classList.remove('active'); });
        current.link.classList.add('active');
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
})();
</script>
{% endblock %}
