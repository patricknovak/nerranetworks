{% extends "base.html.j2" %}

{% block nav_links %}
<li><a href="{{ show_page }}">{{ show_name }}</a></li>
<li><a href="{{ summaries_page }}">Summaries</a></li>
<li><a href="{{ rss_file }}">RSS</a></li>
{% if x_account %}<li><a href="https://x.com/{{ x_account }}" target="_blank" rel="noopener">@{{ x_account }}</a></li>{% endif %}
{% endblock %}

{% block mobile_nav_links %}
<a href="{{ show_page }}" onclick="document.getElementById('mobileMenu').classList.remove('open')">{{ show_name }}</a>
<a href="{{ summaries_page }}" onclick="document.getElementById('mobileMenu').classList.remove('open')">Summaries</a>
<a href="{{ rss_file }}" onclick="document.getElementById('mobileMenu').classList.remove('open')">RSS</a>
{% if x_account %}
<a href="https://x.com/{{ x_account }}" target="_blank" rel="noopener" onclick="document.getElementById('mobileMenu').classList.remove('open')">@{{ x_account }}</a>
{% endif %}
{% endblock %}

{% block content %}
    <!-- Sticky Player -->
    <div id="stickyPlayer" class="nn-sticky-player hidden" aria-live="polite">
        <div class="nn-sticky-player-inner">
            <div class="nn-sticky-meta">
                <div id="stickyNow" class="nn-sticky-title">Now playing</div>
                <div id="stickySub" class="nn-sticky-sub"></div>
            </div>
            <audio id="stickyAudio" class="nn-sticky-audio" controls preload="none"></audio>
            <div class="nn-speed-control">
                <button class="nn-speed-btn" data-speed="0.75">0.75x</button>
                <button class="nn-speed-btn active" data-speed="1">1x</button>
                <button class="nn-speed-btn" data-speed="1.25">1.25x</button>
                <button class="nn-speed-btn" data-speed="1.5">1.5x</button>
                <button class="nn-speed-btn" data-speed="2">2x</button>
            </div>
            <button id="stickyClose" class="nn-sticky-close" aria-label="Close player">&times;</button>
        </div>
    </div>

    <!-- Hero -->
    <section class="summaries-hero">
        <div class="summaries-hero-bg"></div>
        <div class="summaries-hero-inner container">
            {% if podcast_logo_url %}
            <img src="{{ podcast_logo_url }}" alt="{{ show_name }}"
                 style="width:80px;height:80px;border-radius:14px;object-fit:cover;margin:0 auto var(--sp-4);box-shadow:0 8px 30px rgba(0,0,0,0.3);"
                 onerror="this.style.display='none'">
            {% endif %}
            <h1>{{ hero_title | default(show_name) }}</h1>
            <p>{{ hero_subtitle }}</p>
        </div>
    </section>

    <!-- Search & Filter Controls -->
    <div class="nn-controls">
        <input type="text" class="nn-search" id="searchBox" placeholder="Search episodes..." aria-label="Search episodes">
        <button class="nn-filter-btn active" data-filter="all">All</button>
        <button class="nn-filter-btn" data-filter="week">This Week</button>
        <button class="nn-filter-btn" data-filter="month">This Month</button>
        <span class="nn-episode-count" id="episodeCount"></span>
    </div>

    <!-- Summaries -->
    <section style="padding:var(--sp-4) 0 var(--sp-12);">
        <div class="container">
            <div id="summaries-container">
                <div style="text-align:center;color:var(--nn-text-muted);padding:3rem;font-style:italic;">Loading {{ show_name }} summaries...</div>
            </div>
        </div>
    </section>

    <!-- More from Nerra Network -->
    <section class="cross-network nn-section">
        <div class="container">
            <div class="nn-section-header">
                <h2>More from Nerra Network</h2>
            </div>
            <div class="cross-network-grid">
                {% for s in all_shows %}
                {% if s.slug != slug %}
                <a href="{{ s.summaries_page }}" class="cross-network-card">
                    <img src="{{ s.podcast_image }}" alt="{{ s.name }}" loading="lazy">
                    <div class="cross-network-card-info">
                        <div class="cross-network-card-name">{{ s.name }}</div>
                        <div class="cross-network-card-tagline">{{ s.tagline }}</div>
                    </div>
                </a>
                {% endif %}
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}

{% block scripts %}
    <script>
        const JSON_URL = '{{ json_path }}';
        const JSON_FORMAT = '{{ json_format | default("wrapped") }}';
        const SHOW_NAME = {{ show_name | tojson }};

        document.addEventListener('DOMContentLoaded', function() {
            // Speed controls
            document.querySelectorAll('.nn-speed-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const speed = parseFloat(btn.dataset.speed);
                    const audio = document.getElementById('stickyAudio');
                    if (audio) audio.playbackRate = speed;
                    document.querySelectorAll('.nn-speed-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                });
            });

            // Search & filter
            const searchBox = document.getElementById('searchBox');
            const filterBtns = document.querySelectorAll('.nn-filter-btn');
            let currentFilter = 'all';

            searchBox.addEventListener('input', applyFilters);
            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    filterBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    currentFilter = btn.dataset.filter;
                    applyFilters();
                });
            });

            function applyFilters() {
                const query = (searchBox.value || '').toLowerCase();
                const items = document.querySelectorAll('.nn-summary-item');
                const now = new Date();
                let visible = 0;

                items.forEach(item => {
                    const text = (item.textContent || '').toLowerCase();
                    const dateStr = item.dataset.date || '';
                    let dateMatch = true;

                    if (currentFilter === 'week') {
                        const d = new Date(dateStr);
                        dateMatch = (now - d) <= 7 * 86400000;
                    } else if (currentFilter === 'month') {
                        const d = new Date(dateStr);
                        dateMatch = (now - d) <= 31 * 86400000;
                    }

                    const show = text.includes(query) && dateMatch;
                    item.style.display = show ? '' : 'none';
                    if (show) visible++;
                });

                const countEl = document.getElementById('episodeCount');
                if (countEl) countEl.textContent = `${visible} episode${visible !== 1 ? 's' : ''}`;
            }

            loadSummaries();
        });

        async function loadSummaries() {
            try {
                let response;
                try {
                    response = await fetch(JSON_URL);
                    if (!response.ok) throw new Error(`Direct fetch failed: ${response.status}`);
                } catch (directErr) {
                    const proxyUrl = 'https://api.allorigins.win/raw?url=';
                    const fullUrl = new URL(JSON_URL, window.location.href).href;
                    response = await fetch(proxyUrl + encodeURIComponent(fullUrl));
                    if (!response.ok) throw new Error(`Proxy fetch failed: ${response.status}`);
                }

                const data = await response.json();
                const container = document.getElementById('summaries-container');

                const summaries = (JSON_FORMAT === 'array') ? (Array.isArray(data) ? data : [])
                    : (data.summaries || []);

                if (!summaries.length) {
                    container.innerHTML = '<div style="text-align:center;color:var(--nn-text-muted);padding:3rem;font-style:italic;">No summaries available yet. Check back after the next daily update!</div>';
                    return;
                }

                summaries.sort((a, b) => new Date(b.date) - new Date(a.date));

                const html = summaries.map(s => {
                    const audioUrl = s.audio_url || '';
                    const content = s.content || s.summary || '';
                    const title = s.episode_title || '';
                    const date = s.date || '';

                    const audioHtml = audioUrl ? `
                        <div class="nn-summary-actions">
                            <audio class="nn-summary-audio" controls preload="none" src="${escapeAttr(audioUrl)}"></audio>
                            <a class="nn-summary-link" href="${escapeAttr(audioUrl)}" target="_blank" rel="noopener">Download</a>
                            <button class="nn-summary-link" data-share-url="${escapeAttr(audioUrl)}" title="Copy link">Share</button>
                        </div>
                    ` : '';

                    const titleHtml = title ? `<div style="font-weight:600;color:var(--show-color);font-family:var(--font-ui);font-size:0.88rem;">${escapeHtml(title)}</div>` : '';

                    return `
                        <div class="nn-summary-item" data-date="${escapeAttr(date)}">
                            <div class="nn-summary-header">
                                <div>
                                    <div class="nn-summary-date">${formatDate(date)}</div>
                                    ${titleHtml}
                                </div>
                                ${audioHtml}
                            </div>
                            <div class="nn-summary-content">${renderMarkdown(content)}</div>
                        </div>
                    `;
                }).join('');

                container.innerHTML = html;
                initAudioUX(container);
                initShareButtons(container);

                const countEl = document.getElementById('episodeCount');
                if (countEl) countEl.textContent = `${summaries.length} episode${summaries.length !== 1 ? 's' : ''}`;

            } catch (error) {
                console.error('Error loading summaries:', error);
                document.getElementById('summaries-container').innerHTML =
                    '<div style="text-align:center;color:var(--nn-text-muted);padding:3rem;font-style:italic;">Unable to load summaries. Please check back later.</div>';
            }
        }

        function formatDate(dateString) {
            try {
                const date = new Date(dateString);
                return date.toLocaleDateString('en-US', {
                    year: 'numeric', month: 'long', day: 'numeric',
                    weekday: 'long', timeZone: 'UTC'
                });
            } catch { return dateString; }
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text ?? '';
            return div.innerHTML;
        }

        function escapeAttr(text) {
            return String(text ?? '')
                .replace(/&/g, '&amp;')
                .replace(/"/g, '&quot;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;');
        }

        function linkify(text) {
            text = text.replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g,
                '<a href="$2" target="_blank" rel="noopener">$1</a>');
            text = text.replace(/(https?:\/\/[^\s<]+)/g,
                '<a href="$1" target="_blank" rel="noopener">$1</a>');
            return text;
        }

        function renderMarkdown(md) {
            const safe = escapeHtml(md).replace(/\r\n/g, '\n');
            const lines = safe.split('\n');
            let out = '';
            let inList = false;

            const flush = () => { if (inList) { out += '</ul>'; inList = false; } };

            for (const rawLine of lines) {
                const trimmed = rawLine.trim();

                if (!trimmed) { flush(); out += '<p></p>'; continue; }

                if (trimmed.startsWith('### ')) { flush(); out += `<h3>${linkify(trimmed.slice(4))}</h3>`; continue; }
                if (trimmed.startsWith('## '))  { flush(); out += `<h2>${linkify(trimmed.slice(3))}</h2>`; continue; }
                if (trimmed.startsWith('# '))   { flush(); out += `<h1>${linkify(trimmed.slice(2))}</h1>`; continue; }

                if (/^[-\u2022]\s+/.test(trimmed)) {
                    if (!inList) { out += '<ul>'; inList = true; }
                    out += `<li>${linkify(trimmed.replace(/^[-\u2022]\s+/, ''))}</li>`;
                    continue;
                }

                flush();
                let p = trimmed.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
                p = linkify(p);
                out += `<p>${p}</p>`;
            }

            flush();
            return out.replace(/<p><\/p>/g, '<div style="height:0.6rem"></div>');
        }

        // Sticky player + per-card audio UX
        function initAudioUX(container) {
            const stickyPlayer = document.getElementById('stickyPlayer');
            const stickyAudio = document.getElementById('stickyAudio');
            const stickyNow = document.getElementById('stickyNow');
            const stickySub = document.getElementById('stickySub');
            const stickyClose = document.getElementById('stickyClose');

            let activeCardAudio = null;

            const cardAudios = Array.from(container.querySelectorAll('audio.nn-summary-audio'));

            function pauseAllCardAudios() {
                for (const a of cardAudios) { try { a.pause(); } catch {} }
            }

            function setSticky(meta, audioEl) {
                activeCardAudio = audioEl;
                stickyNow.textContent = meta?.title || 'Now playing';
                stickySub.textContent = meta?.date || '';
                if (audioEl?.src && stickyAudio.src !== audioEl.src) {
                    stickyAudio.src = audioEl.src;
                }
                stickyPlayer.classList.remove('hidden');
            }

            for (const audioEl of cardAudios) {
                const card = audioEl.closest('.nn-summary-item');
                const dateText = card?.querySelector('.nn-summary-date')?.textContent?.trim() || '';
                const titleGuess =
                    card?.querySelector('.nn-summary-content h1, .nn-summary-content h2, .nn-summary-content h3')?.textContent?.trim() ||
                    'Episode';
                const meta = { date: dateText, title: titleGuess };

                audioEl.addEventListener('play', (e) => {
                    e.preventDefault();
                    pauseAllCardAudios();
                    setSticky(meta, audioEl);
                    try { audioEl.pause(); } catch {}
                    try { stickyAudio.currentTime = audioEl.currentTime || 0; } catch {}
                    stickyAudio.play().catch(() => {});
                });
            }

            stickyAudio.addEventListener('timeupdate', () => {
                if (activeCardAudio) {
                    try { activeCardAudio.currentTime = stickyAudio.currentTime; } catch {}
                }
            });

            stickyClose?.addEventListener('click', () => {
                try { stickyAudio.pause(); } catch {}
                stickyPlayer.classList.add('hidden');
                activeCardAudio = null;
            });
        }

        // Share buttons
        function initShareButtons(container) {
            container.querySelectorAll('[data-share-url]').forEach(btn => {
                btn.addEventListener('click', async () => {
                    const url = btn.dataset.shareUrl;
                    try {
                        await navigator.clipboard.writeText(url);
                        btn.textContent = 'Copied!';
                        setTimeout(() => { btn.textContent = 'Share'; }, 2000);
                    } catch {
                        const input = document.createElement('input');
                        input.value = url;
                        document.body.appendChild(input);
                        input.select();
                        document.execCommand('copy');
                        document.body.removeChild(input);
                        btn.textContent = 'Copied!';
                        setTimeout(() => { btn.textContent = 'Share'; }, 2000);
                    }
                });
            });
        }
    </script>
{% endblock %}
